# .env.example
# ==========================================
# PRODUCTION POSTGRESQL DATABASE URL
# ==========================================
# To switch from SQLite (which causes "database is locked" errors in production)
# to PostgreSQL, simply uncomment the DATABASE_URL below and enter your credentials.

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/air_dispatch_tms"

# Optional: Overwrite other settings
# BACKEND_PORT=8000
# LOG_LEVEL=INFO
# CORS_ORIGINS='["http://localhost:5173", "http://yourdomain.com"]'
